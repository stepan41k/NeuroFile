<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Neuro" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorSurface">@color/bg_sidebar</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_input</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <item name="android:windowBackground">@color/bg_app</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/bg_sidebar</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds" tools:targetApi="l">true</item>

        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <item name="materialButtonStyle">@style/Button.Primary</item>
        <item name="textInputStyle">@style/TextInput.OutlinedBox</item>
        <item name="chipStyle">@style/Chip.Filter</item>
    </style>

    <style name="Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="TextInput.OutlinedBox" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_muted</item>
    </style>

    <style name="Chip.Filter" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/bg_input</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="chipIconTint">@color/text_secondary</item>
        <item name="rippleColor">@color/primary</item>
        <item name="chipStrokeColor">@color/bg_border</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>
</resources>
